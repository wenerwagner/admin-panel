# Local Docker Compose ports
API_PORT=3000
WEB_PORT=8080
POSTGRES_PORT=5432

# Local PostgreSQL settings
POSTGRES_USER=admin_panel
POSTGRES_PASSWORD=admin_panel_password
POSTGRES_DB=admin_panel

# API environment
NODE_ENV=development
DATABASE_URL=postgres://admin_panel:admin_panel_password@localhost:5432/admin_panel
SESSION_COOKIE_NAME=admin_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=8
CSRF_SECRET=local_csrf_secret_change_me_before_production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
TRUST_PROXY=false
LOG_LEVEL=info
